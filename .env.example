# UI configuration
UI_API_BASE_URL=http://localhost:8000
UI_REQUEST_TIMEOUT=120

# API configuration
API_TITLE="Focused Research Agent API"
API_VERSION=1.0.0
API_DEBUG=false

# LLM configuration
# Ollama cloud alternative
LLM_PROVIDER=openai
LLM_MODEL=mimo_v2.5_pro
LLM_API_KEY=tp-cu31ai89y0j9vsxjddkjarm0k8c5j23z69iba21kat9gko9u
LLM_TEMPERATURE=0.0
LLM_MAX_RETRIES=2
LLM_MAX_TOKENS=4096

# Groq alternative (comment above 3 lines for Ollama cloud and Ollama local and uncomment below to switch)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=your_groq_key_here

# Ollama Local alternative (no API key) (comment above 3 lines for Ollama cloud and groq and uncomment below to switch)
#LLM_PROVIDER=ollama
#LLM_MODEL=llama3.2:3b
#LLM_API_KEY=not-needed

# Search configuration
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=your_key_here
SEARCH_DEPTH=basic
SEARCH_MAX_RESULTS=5

# Database configuration
DATABASE_URL=sqlite:///./research_agent.db